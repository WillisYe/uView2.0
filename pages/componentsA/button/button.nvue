<template>
	<view class="u-page">
		<view
			v-for="section in demoSections"
			:key="section.title"
			class="u-demo-block"
		>
			<text class="u-demo-block__title">{{ section.title }}</text>
			<view
				v-for="(contentBlock, contentIndex) in section.contentBlocks"
				:key="section.title + contentIndex"
				class="u-demo-block__content"
				:style="contentBlock.style || ''"
			>
				<view
					v-for="item in contentBlock.buttons"
					:key="item.text + item.type + item.size + item.color"
					class="u-page__button-item"
				>
					<u-button
						:text="item.text"
						:size="item.size || 'normal'"
						:type="item.type"
						:disabled="item.disabled"
						:plain="item.plain"
						:hairline="item.hairline"
						:loading="item.loading"
						:loadingText="item.loadingText"
						:loadingMode="item.loadingMode"
						:icon="item.icon"
						:shape="item.shape"
						:color="item.color"
						:class="item.className"
						@click="item.click ? click : null"
					></u-button>
				</view>
			</view>
		</view>
	</view>
</template>

<script>
	export default {
		data() {
			return {
				demoSections: [
					{
						title: '按钮类型',
